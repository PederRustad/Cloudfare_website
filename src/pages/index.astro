---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
  title="Bitcoin Strategi | Strategisk rådgivning"
  description="Vi hjelper norske bedrifter med å innføre en bitcoinstrategi med tydelige rammer og trygg gjennomføring."
>
  <section class="home-minimal reveal delay-1">
    <div class="home-logo" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 80 80" fill="none">
        <rect x="10" y="10" width="24" height="24" rx="4" stroke="currentColor" stroke-width="6"></rect>
        <rect x="46" y="10" width="24" height="24" rx="4" stroke="currentColor" stroke-width="6"></rect>
        <rect x="10" y="46" width="24" height="24" rx="4" stroke="currentColor" stroke-width="6"></rect>
        <rect x="46" y="46" width="24" height="24" rx="4" fill="currentColor"></rect>
        <path d="M34 22h12M22 34v12M58 34v12M34 58h12" stroke="currentColor" stroke-width="6" stroke-linecap="round"></path>
      </svg>
    </div>

    <p class="home-statement">
      Vi hjelper norske bedrifter med å innføre en bitcoinstrategi med tydelige
      rammer, kontroll og langsiktighet.
    </p>

    <div class="home-links">
      <a href="/smb">For bedrifter</a>
      <a href="/enterprise">Større selskap</a>
      <a href="/contact">Kontakt</a>
    </div>
  </section>
</SiteLayout>
