---
import SiteLayout from "../layouts/SiteLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import { articles } from "../data/articles";

const featured = articles.slice(0, 3);
---

<SiteLayout
  title="Bitcoin Strategi | Bitcoin-rådgivning og strategi i Norge"
  description="Bygg en konkret bitcoin-strategi med fokus på risiko, struktur og praktisk gjennomføring."
>
  <section class="hero hero-split reveal delay-1 section">
    <article class="hero-copy">
      <p class="eyebrow">Strategisk bitcoin-rådgivning</p>
      <h1>Bygg en bitcoin-strategi som tåler både eufori og nedtur.</h1>
      <p class="lead">
        Vi hjelper privatpersoner og mindre selskaper med å gå fra impuls og
        usikkerhet til en tydelig plan for innkjøp, oppbevaring og oppfølging.
      </p>
      <div class="inline-actions">
        <a class="btn primary" href="/contact">Bestill strategisamtale</a>
        <a class="btn ghost" href="#tjenester">Se tjenester</a>
      </div>
    </article>

    <aside class="hero-board" aria-label="Strategimoduler">
      <p class="board-title">Din strategi, komprimert</p>
      <ul class="board-list">
        <li><span>Rammeverk</span><strong>mål + tidshorisont</strong></li>
        <li><span>Innkjøp</span><strong>faste regler og størrelse</strong></li>
        <li><span>Custody</span><strong>wallet + backup-rutiner</strong></li>
        <li><span>Oppfølging</span><strong>rolig beslutningsprosess</strong></li>
      </ul>

      <div class="network-illustration" aria-hidden="true">
        <svg class="network-lines" viewBox="0 0 320 140" role="presentation">
          <line x1="30" y1="110" x2="95" y2="70"></line>
          <line x1="95" y1="70" x2="160" y2="40"></line>
          <line x1="160" y1="40" x2="235" y2="72"></line>
          <line x1="235" y1="72" x2="292" y2="110"></line>
          <line x1="95" y1="70" x2="235" y2="72"></line>
          <line x1="30" y1="110" x2="160" y2="40"></line>
        </svg>
        <span class="node node-a"></span>
        <span class="node node-b"></span>
        <span class="node node-c"></span>
        <span class="node node-d"></span>
        <span class="node node-e"></span>
      </div>
    </aside>
  </section>

  <section class="section reveal delay-2" id="tjenester">
    <p class="eyebrow">Tjenester</p>
    <h2>Tre moduler for å få kontroll på helheten.</h2>
    <div class="modules-grid section">
      <article class="module-card">
        <div class="module-visual module-visual-1" aria-hidden="true">
          <span></span><span></span><span></span>
        </div>
        <p class="module-index">01</p>
        <h3>Strategi og risikoramme</h3>
        <p>
          Vi definerer mål, tidshorisont og akseptabel risiko slik at bitcoin får
          riktig rolle i totalporteføljen din.
        </p>
      </article>

      <article class="module-card">
        <div class="module-visual module-visual-2" aria-hidden="true">
          <span></span><span></span><span></span>
        </div>
        <p class="module-index">02</p>
        <h3>Innkjøp og oppbevaring</h3>
        <p>
          Konkrete anbefalinger for kjøpsstruktur, wallet-oppsett og sikker
          lagring av nøkler.
        </p>
      </article>

      <article class="module-card">
        <div class="module-visual module-visual-3" aria-hidden="true">
          <span></span><span></span><span></span>
        </div>
        <p class="module-index">03</p>
        <h3>Rutiner og beslutningsstøtte</h3>
        <p>
          Tydelige sjekkpunkter for når du handler, når du holder, og når du
          gjør ingenting.
        </p>
      </article>
    </div>
  </section>

  <section class="section reveal delay-3 process-section">
    <p class="eyebrow">Slik jobber vi</p>
    <h2>Rask prosess, tydelige leveranser.</h2>
    <div class="process-grid section">
      <article class="process-card">
        <p class="process-step">Steg 1</p>
        <h3>Kartlegging</h3>
        <p>Vi går gjennom nåsituasjon, risikoprofil og mål på 45 minutter.</p>
      </article>
      <article class="process-card">
        <p class="process-step">Steg 2</p>
        <h3>Strategidokument</h3>
        <p>Du får en konkret plan for eksponering, kjøp, custody og oppfølging.</p>
      </article>
      <article class="process-card">
        <p class="process-step">Steg 3</p>
        <h3>Implementering</h3>
        <p>Vi setter opp rutiner og beslutningsrammer du kan følge over tid.</p>
      </article>
    </div>
  </section>

  <section class="grid-two section reveal delay-4">
    <article class="panel">
      <p class="eyebrow">For hvem</p>
      <h2>For deg som vil ha struktur, ikke støy.</h2>
      <ul class="bullet-list">
        <li>Privatpersoner med betydelig sparekapital</li>
        <li>Bedrifter som vurderer bitcoin i balansen</li>
        <li>Investorer som vil redusere ad hoc-beslutninger</li>
      </ul>
    </article>

    <article class="panel panel-accent">
      <p class="eyebrow">Klar for neste steg?</p>
      <h2>Vi kan starte med en enkel vurderingssamtale.</h2>
      <p>
        Du får en tydelig anbefaling på hva du bør gjøre nå, og hva du bør
        vente med.
      </p>
      <div class="inline-actions">
        <a class="btn primary" href="/contact">Kontakt oss</a>
      </div>
    </article>
  </section>

  <section class="section reveal delay-4">
    <p class="eyebrow">Innsikt</p>
    <h2>Praktiske artikler for langsiktige beslutninger</h2>
    <div class="article-list section">
      {featured.map((article) => <ArticleCard article={article} />)}
    </div>
  </section>
</SiteLayout>
