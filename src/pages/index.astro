---
import SiteLayout from "../layouts/SiteLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import { articles } from "../data/articles";

const featured = articles.slice(0, 3);
---

<SiteLayout
  title="Bitcoin Strategi | Compliance-first bitcoinrådgivning for norske bedrifter"
  description="Vi hjelper norske bedrifter med å innføre bitcoin på en trygg, styrt og revisjonsklar måte."
>
  <section class="hero hero-split reveal delay-1 section">
    <article class="hero-copy">
      <p class="eyebrow">Compliance-first bitcoinrådgivning</p>
      <h1>Fra idé til styregodkjent bitcoin-policy på 30 dager.</h1>
      <p class="lead">
        Vi hjelper norske små og store virksomheter med å etablere rammeverk for
        risiko, governance, skatt/regnskap og operativ gjennomføring. Målet er
        kontroll, ikke markedsstøy.
      </p>
      <div class="inline-actions">
        <a class="btn primary" href="/contact">Book strategimøte</a>
        <a class="btn ghost" href="/compliance#policy-eksempel">Se eksempel på policy</a>
      </div>
      <div class="stat-strip">
        <article class="stat-card">
          <p class="module-index">Mål 6 mnd</p>
          <h3>10 SMB + 2 pilotkunder</h3>
        </article>
        <article class="stat-card">
          <p class="module-index">Leveranse</p>
          <h3>Risikokart + policy + rutiner</h3>
        </article>
        <article class="stat-card">
          <p class="module-index">Fokus</p>
          <h3>Beslutningskraft for ledelse/styre</h3>
        </article>
      </div>
    </article>

    <aside class="hero-board" aria-label="Strategimoduler">
      <p class="board-title">Revisjonsklar modell</p>
      <ul class="board-list">
        <li><span>Mandat</span><strong>mål + tidshorisont</strong></li>
        <li><span>Governance</span><strong>styreforankring + policy</strong></li>
        <li><span>Skatt/regnskap</span><strong>sporbar struktur</strong></li>
        <li><span>Drift</span><strong>kontroller + oppfølging</strong></li>
      </ul>

      <div class="network-illustration" aria-hidden="true">
        <svg class="network-world" viewBox="0 0 640 260" role="presentation">
          <path d="M44 86l22-22 48-12 34 7 18 16-5 24-31 18-44 4-30-8-18-16z"></path>
          <path d="M148 122l26-6 15 10-5 18-20 8-18-6-8-14z"></path>
          <path d="M164 168l30-4 20 10-7 31-23 23-19-12-10-19z"></path>
          <path d="M286 68l24-14 48-6 48 9 21 19-8 20-34 14-53 2-28-13z"></path>
          <path d="M354 112l42 5 24 20-9 27-32 18-24-12-10-25z"></path>
          <path d="M420 92l53-10 74 8 45 24-7 22-57 18-64-2-45-20z"></path>
          <path d="M536 168l42-8 30 11 9 19-22 18-42 2-24-14z"></path>
        </svg>

        <svg class="network-lines" viewBox="0 0 640 260" role="presentation">
          <path class="core" d="M116 98Q228 74 356 86"></path>
          <path class="core" d="M116 98Q308 90 518 94"></path>
          <path class="core" d="M356 86Q438 80 518 94"></path>
          <path class="core" d="M356 86Q358 120 364 146"></path>
          <path class="core" d="M116 102Q158 138 186 188"></path>
          <path class="core" d="M356 90Q272 138 186 188"></path>
          <path class="core" d="M518 96Q540 136 560 184"></path>
          <path class="core" d="M364 148Q454 168 560 184"></path>
          <path d="M78 106Q228 104 356 86"></path>
          <path d="M98 84Q232 90 518 94"></path>
          <path d="M138 126Q252 124 518 96"></path>
          <path d="M164 116Q300 108 356 86"></path>
          <path d="M174 114Q266 146 364 148"></path>
          <path d="M184 188Q314 214 560 184"></path>
          <path d="M204 208Q320 182 518 96"></path>
          <path d="M364 148Q322 182 212 220"></path>
          <path d="M364 148Q432 136 482 122"></path>
          <path d="M364 148Q466 160 608 180"></path>
          <path d="M356 86Q446 118 560 184"></path>
          <path d="M518 94Q436 112 364 148"></path>
          <path d="M560 184Q478 136 356 86"></path>
          <path d="M92 70Q180 86 356 86"></path>
          <path d="M74 122Q164 126 186 188"></path>
          <path d="M436 138Q500 158 560 184"></path>
        </svg>

        <svg class="network-flow" viewBox="0 0 640 260" role="presentation">
          <path d="M116 98Q228 74 356 86"></path>
          <path d="M116 98Q308 90 518 94"></path>
          <path d="M356 86Q438 80 518 94"></path>
          <path d="M356 90Q272 138 186 188"></path>
          <path d="M518 96Q540 136 560 184"></path>
          <path d="M364 148Q454 168 560 184"></path>
        </svg>

        <div class="network-nodes">
          <span class="node hub" style="--x:18%;--y:37%;--delay:0s;"></span>
          <span class="node hub" style="--x:55.6%;--y:33.5%;--delay:0.5s;"></span>
          <span class="node hub" style="--x:81.2%;--y:36%;--delay:1s;"></span>
          <span class="node hub warm" style="--x:57.2%;--y:56%;--delay:1.5s;"></span>
          <span class="node hub mint" style="--x:29%;--y:72%;--delay:2s;"></span>

          <span class="node" style="--x:11%;--y:33%;--delay:0.2s;"></span>
          <span class="node mint" style="--x:13%;--y:40%;--delay:0.9s;"></span>
          <span class="node warm" style="--x:15%;--y:45%;--delay:1.8s;"></span>
          <span class="node" style="--x:21%;--y:30%;--delay:1.3s;"></span>
          <span class="node pink" style="--x:23%;--y:42%;--delay:2.4s;"></span>
          <span class="node mint" style="--x:26%;--y:48%;--delay:2.9s;"></span>
          <span class="node warm" style="--x:30%;--y:61%;--delay:0.7s;"></span>
          <span class="node" style="--x:32%;--y:78%;--delay:2.1s;"></span>

          <span class="node" style="--x:49%;--y:31%;--delay:0.4s;"></span>
          <span class="node mint" style="--x:51%;--y:40%;--delay:1.1s;"></span>
          <span class="node pink" style="--x:54%;--y:29%;--delay:2.2s;"></span>
          <span class="node warm" style="--x:58%;--y:36%;--delay:2.7s;"></span>
          <span class="node" style="--x:60%;--y:44%;--delay:3.2s;"></span>
          <span class="node mint" style="--x:56%;--y:62%;--delay:1.4s;"></span>
          <span class="node warm" style="--x:59%;--y:68%;--delay:2.6s;"></span>

          <span class="node" style="--x:69%;--y:34%;--delay:0.6s;"></span>
          <span class="node mint" style="--x:73%;--y:38%;--delay:1.6s;"></span>
          <span class="node pink" style="--x:76%;--y:44%;--delay:2.8s;"></span>
          <span class="node warm" style="--x:79%;--y:52%;--delay:3.1s;"></span>
          <span class="node" style="--x:84%;--y:47%;--delay:0.95s;"></span>
          <span class="node mint" style="--x:88%;--y:41%;--delay:1.95s;"></span>
          <span class="node pink" style="--x:90%;--y:66%;--delay:2.95s;"></span>
          <span class="node warm" style="--x:86%;--y:73%;--delay:3.4s;"></span>
        </div>
      </div>
    </aside>
  </section>

  <section class="section reveal delay-2" id="segmenter">
    <p class="eyebrow">Segmenter</p>
    <h2>Tilpasset små, mellomstore og store virksomheter i Norge.</h2>
    <div class="segment-grid section">
      <article class="panel">
        <p class="pill">SMB (1-49 ansatte)</p>
        <h3>Bedriftsstart Bitcoin</h3>
        <p>
          For virksomheter som vil etablere en enkel, trygg og forståelig modell
          uten å bygge unødig kompleksitet.
        </p>
        <ul class="bullet-list">
          <li>2 workshops for ledergruppe</li>
          <li>Enkel policy + risikoramme</li>
          <li>90-dagers implementeringsplan</li>
        </ul>
        <p class="price-tag">35k-90k NOK</p>
        <div class="inline-actions">
          <a class="btn ghost" href="/smb">Se SMB-opplegg</a>
        </div>
      </article>

      <article class="panel panel-accent">
        <p class="pill">Mid-market & enterprise</p>
        <h3>Treasury & Governance / Enterprise Program</h3>
        <p>
          For selskaper som trenger styreforankring, internkontroll,
          leverandørstruktur og kvartalsvis oppfølging.
        </p>
        <ul class="bullet-list">
          <li>Policy-dokument + kontrollpunkter</li>
          <li>Compliance blueprint og driftsmodell</li>
          <li>Opplæring for økonomi, juridisk og IT</li>
        </ul>
        <p class="price-tag">120k-350k NOK / fra 500k NOK + retainer</p>
        <div class="inline-actions">
          <a class="btn primary" href="/enterprise">Se enterprise-opplegg</a>
        </div>
      </article>
    </div>
  </section>

  <section class="section reveal delay-3" id="tilbud">
    <p class="eyebrow">Tilbud</p>
    <h2>Pakker du kan ta i bruk fra dag én.</h2>
    <div class="offer-grid section">
      <article class="module-card">
        <p class="module-index">Pakke A</p>
        <h3>Bedriftsstart Bitcoin</h3>
        <p>SMB-løp med tydelig policy, risikoramme og 90-dagers plan.</p>
        <p class="price-tag">35k-90k NOK</p>
      </article>
      <article class="module-card">
        <p class="module-index">Pakke B</p>
        <h3>Treasury & Governance</h3>
        <p>Styrenivå, internkontroll, rapportering og leverandørkart.</p>
        <p class="price-tag">120k-350k NOK</p>
      </article>
      <article class="module-card">
        <p class="module-index">Pakke C</p>
        <h3>Enterprise Program</h3>
        <p>Konsernpolicy, compliance-spor og opplæring på tvers av funksjoner.</p>
        <p class="price-tag">Fra 500k NOK + retainer</p>
      </article>
      <article class="module-card">
        <p class="module-index">Retainer</p>
        <h3>Kvartalsvis beslutningsstøtte</h3>
        <p>Månedlig rådgivning, policy review og markedsnotat for ledelsen.</p>
        <p class="price-tag">Pris etter omfang</p>
      </article>
    </div>
  </section>

  <section class="section reveal delay-3 process-section">
    <p class="eyebrow">Metodikk</p>
    <h2>Fire steg for trygg innføring i virksomheten.</h2>
    <div class="process-grid process-grid-4 section">
      <article class="process-card">
        <p class="process-step">Steg 1</p>
        <h3>Kartlegging</h3>
        <p>Mål, risiko og beslutningsstruktur med ledelse/styre.</p>
      </article>
      <article class="process-card">
        <p class="process-step">Steg 2</p>
        <h3>Policy og governance</h3>
        <p>Formalisert policy, roller, kontroller og rapportering.</p>
      </article>
      <article class="process-card">
        <p class="process-step">Steg 3</p>
        <h3>Implementering</h3>
        <p>Operative rutiner for custody, prosess og dokumentasjon.</p>
      </article>
      <article class="process-card">
        <p class="process-step">Steg 4</p>
        <h3>Oppfølging</h3>
        <p>Kvartalsvis gjennomgang, KPI-er og justering av mandat.</p>
      </article>
    </div>
  </section>

  <section class="grid-two section reveal delay-4">
    <article class="panel">
      <p class="eyebrow">Regulatorisk strategi</p>
      <h2>To spor for gjennomføring i dagens marked.</h2>
      <ul class="bullet-list">
        <li>Spor 1 (nå): opplæring, policy, risikoprosess og implementeringsstøtte</li>
        <li>Spor 2 (vekst): partnerskap med lisensiert aktør eller eget tillatelsesløp</li>
        <li>Skatt, regnskap og MVA forankres i leveransen fra oppstart</li>
      </ul>
      <div class="inline-actions">
        <a class="btn ghost" href="/compliance">Les compliance-rammeverk</a>
      </div>
    </article>

    <article class="panel panel-accent">
      <p class="eyebrow">Go-to-market</p>
      <h2>Første fokus: profesjonelle tjenester og tech.</h2>
      <ul class="bullet-list">
        <li>LinkedIn-faginnhold for CFO/CEO</li>
        <li>Frokostseminarer med regnskapsbyrå, revisor og advokat</li>
        <li>Partnerskap med treasury- og regnskapsmiljøer</li>
      </ul>
      <div class="inline-actions">
        <a class="btn primary" href="/bransjer">Se bransjeforslag</a>
      </div>
    </article>
  </section>

  <section class="section reveal delay-4">
    <p class="eyebrow">Innsikt</p>
    <h2>Artikler, whitepaper og webinar for ledelse og styre.</h2>
    <div class="article-list section">
      {featured.map((article) => <ArticleCard article={article} basePath="/innsikt" />)}
    </div>
    <div class="inline-actions">
      <a class="btn ghost" href="/innsikt">Se alle innsikter</a>
    </div>
  </section>
</SiteLayout>
