---
import SiteLayout from "../layouts/SiteLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import { articles } from "../data/articles";

const featured = articles.slice(0, 3);
---

<SiteLayout
  title="Bitcoin Strategi | Lønnsom og trygg bitcoin-strategi for normale mennesker"
  description="Rådgivning og strukturert veiledning for deg som vil bruke bitcoin bevisst – med fokus på risiko, strategi og praktisk gjennomføring."
>
  <section class="hero hero-split fade-up delay-1 section">
    <div class="hero-copy">
      <p class="eyebrow">Lønnsom og kontrollert</p>
      <h1>Bygg en bitcoin-strategi som fortsatt gir mening om fem år.</h1>
      <p class="lead">
        Bitcoin Strategi hjelper privatpersoner og mindre bedrifter å gå fra
        magefølelse og FOMO til en konkret plan for kjøp, oppbevaring og
        oppfølging. Ingen hype – bare tydelige steg og realistisk risiko.
      </p>
      <div class="inline-actions">
        <a class="btn primary" href="/contact">Bestill en samtale</a>
        <a class="btn ghost" href="/about">Se hvordan vi jobber</a>
      </div>
    </div>

    <div class="hero-illustration" aria-hidden="true">
      <div class="pillars-diagram">
        <div class="pillars-header">Din bitcoin-strategi</div>
        <div class="pillars-grid">
          <div class="pillar-card">
            <p class="pillar-label">Strategi</p>
            <p class="pillar-body">Mål, tidshorisont og rolle i porteføljen.</p>
          </div>
          <div class="pillar-card">
            <p class="pillar-label">Innkjøp</p>
            <p class="pillar-body">Størrelse per kjøp, tempo og verktøy.</p>
          </div>
          <div class="pillar-card">
            <p class="pillar-label">Oppbevaring</p>
            <p class="pillar-body">Wallet-struktur, nøkler og rutiner.</p>
          </div>
          <div class="pillar-card">
            <p class="pillar-label">Oppfølging</p>
            <p class="pillar-body">Hva du faktisk gjør når det svinger.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section fade-up delay-2 modules" aria-label="Moduler">
    <p class="eyebrow">3 moduler for å få kontroll</p>
    <h2>Fra «jeg burde gjøre noe» til en konkret plan du faktisk følger.</h2>
    <div class="modules-grid">
      <article class="module-card">
        <p class="module-index">1</p>
        <h3>Strategi og risikoramme</h3>
        <p>
          Vi kartlegger situasjon, mål og tidshorisont. Du får en tydelig
          risikoramme og forslag til hvor stor del bitcoin bør være av total
          formue.
        </p>
      </article>
      <article class="module-card">
        <p class="module-index">2</p>
        <h3>Innkjøp og oppbevaring</h3>
        <p>
          Konkrete anbefalinger for hvor og hvordan du kjøper, hvordan du
          organiserer wallets, og hvordan du reduserer praktisk og teknisk
          risiko.
        </p>
      </article>
      <article class="module-card">
        <p class="module-index">3</p>
        <h3>Rutiner og oppfølging</h3>
        <p>
          Enkle rutiner for når du justerer, når du gjør ingenting, og hvordan
          du håndterer store bevegelser uten å gå i følelsesfellen.
        </p>
      </article>
    </div>
  </section>

  <section class="section fade-up delay-3 fit-section">
    <p class="eyebrow">Hvem dette passer for</p>
    <h2>Du trenger ikke være «krypto-person» for å ta bitcoin på alvor.</h2>
    <div class="grid-two">
      <article class="panel">
        <h3>Typiske kunder</h3>
        <ul class="bullet-list">
          <li>Profesjonelle med sparekapital som vil unngå dyre nybegynnerfeil.</li>
          <li>Små bedrifter som vurderer bitcoin som del av kontantbeholdningen.</li>
          <li>Erfarne investorer som vil ha en strukturert plan, ikke enkelttips.</li>
        </ul>
      </article>
      <article class="panel">
        <h3>Typiske resultater</h3>
        <ul class="bullet-list">
          <li>Klar risikoramme og dokumentert strategi.</li>
          <li>Bedre sikkerhet rundt nøkler og oppbevaring.</li>
          <li>Mindre stress når prisen svinger opp og ned.</li>
        </ul>
      </article>
    </div>
  </section>

  <section class="section fade-up delay-4">
    <p class="eyebrow">Artikler</p>
    <h2>Fordyp deg i rolige, praktiske perspektiver</h2>
    <div class="article-list section">
      {featured.map((article) => <ArticleCard article={article} />)}
    </div>
  </section>
</SiteLayout>
