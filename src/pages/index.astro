---
import SiteLayout from "../layouts/SiteLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import { articles } from "../data/articles";

const featured = articles.slice(0, 3);
---

<SiteLayout
  title="Bitcoin Strategi | Strategic Bitcoin Intelligence"
  description="A darker, modern Bitcoin strategy site focused on disciplined execution, risk controls, and cycle-aware planning."
>
  <section class="hero hero-grid section reveal">
    <article class="hero-copy">
      <p class="eyebrow">[ Bitcoin Strategy Lab ]</p>
      <h1>Build a strong Bitcoin playbook before the market gets emotional.</h1>
      <p class="lead">
        We help you operate with structure in volatile markets: thesis clarity,
        risk limits, custody discipline, and repeatable weekly routines.
      </p>
      <div class="inline-actions">
        <a class="btn primary" href="/articles">Read strategy articles</a>
        <a class="btn ghost" href="/about">How we work</a>
      </div>
    </article>

    <aside class="hero-terminal" aria-label="Market discipline checklist">
      <p class="terminal-title">Strategy Snapshot</p>
      <ul>
        <li><span>Hard cap focus</span><strong>21M supply</strong></li>
        <li><span>Execution mode</span><strong>Rule-based</strong></li>
        <li><span>Risk profile</span><strong>Capital first</strong></li>
        <li><span>Behavior edge</span><strong>Consistency</strong></li>
      </ul>
      <p class="terminal-foot">Updated for long-cycle thinking</p>
    </aside>
  </section>

  <section class="ticker-row section reveal">
    <article class="ticker-card">
      <p class="ticker-label">Block cadence</p>
      <p class="ticker-value">~10 min</p>
    </article>
    <article class="ticker-card">
      <p class="ticker-label">Monetary limit</p>
      <p class="ticker-value">21,000,000 BTC</p>
    </article>
    <article class="ticker-card">
      <p class="ticker-label">Primary objective</p>
      <p class="ticker-value">Preserve conviction</p>
    </article>
    <article class="ticker-card">
      <p class="ticker-label">Method</p>
      <p class="ticker-value">Process > prediction</p>
    </article>
  </section>

  <section class="section reveal">
    <p class="eyebrow">[ Core Framework ]</p>
    <h2>Three systems that keep your decision quality high.</h2>
    <div class="grid-three section">
      <article class="panel feature-panel">
        <p class="pill">Risk System</p>
        <h3>Define loss limits before entries.</h3>
        <p>
          Position size and downside tolerance are set before any buy, so volatility
          does not force bad decisions later.
        </p>
      </article>

      <article class="panel feature-panel">
        <p class="pill">Behavior System</p>
        <h3>Convert stress into routine.</h3>
        <p>
          Weekly review cadence, fixed contribution windows, and rules that remove
          emotional impulse from execution.
        </p>
      </article>

      <article class="panel feature-panel">
        <p class="pill">Security System</p>
        <h3>Treat custody as strategy.</h3>
        <p>
          Storage model, backup testing, and access controls are part of your
          portfolio plan, not an afterthought.
        </p>
      </article>
    </div>
  </section>

  <section class="grid-two section reveal">
    <article class="panel depth-panel">
      <p class="eyebrow">[ Market posture ]</p>
      <h2>Calm in euphoria, calm in drawdowns.</h2>
      <p>
        You do not need perfect timing to outperform chaos. You need durable
        behavior, clear downside constraints, and a thesis that survives noise.
      </p>
      <ul class="bullet-list">
        <li>Define invalidation levels early</li>
        <li>Track liquidity before increasing exposure</li>
        <li>Measure execution quality, not daily price</li>
      </ul>
    </article>

    <article class="panel depth-panel accent-panel">
      <p class="eyebrow">[ Build in public ]</p>
      <h2>Astro-powered and built for speed.</h2>
      <p>
        The site now runs on a clean Astro stack with Cloudflare deployment,
        making updates faster and easier to scale.
      </p>
      <div class="inline-actions">
        <a class="btn primary" href="/contact">Work with us</a>
      </div>
    </article>
  </section>

  <section class="section reveal">
    <p class="eyebrow">[ Featured Reads ]</p>
    <h2>Start with the practical playbooks</h2>
    <div class="article-list section">
      {featured.map((article) => <ArticleCard article={article} />)}
    </div>
  </section>
</SiteLayout>
