---
import SiteLayout from "../layouts/SiteLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import { articles } from "../data/articles";

const featured = articles.slice(0, 3);
---

<SiteLayout
  title="Bitcoin Strategi | Bitcoin-rådgivning og strategi i Norge"
  description="Bygg en konkret bitcoin-strategi med fokus på risiko, struktur og praktisk gjennomføring."
>
  <section class="hero hero-split reveal delay-1 section">
    <article class="hero-copy">
      <p class="eyebrow">Strategisk bitcoin-rådgivning</p>
      <h1>Bygg en bitcoin-strategi som tåler både eufori og nedtur.</h1>
      <p class="lead">
        Vi hjelper privatpersoner og mindre selskaper med å gå fra impuls og
        usikkerhet til en tydelig plan for innkjøp, oppbevaring og oppfølging.
      </p>
      <div class="inline-actions">
        <a class="btn primary" href="/contact">Bestill strategisamtale</a>
        <a class="btn ghost" href="#tjenester">Se tjenester</a>
      </div>
    </article>

    <aside class="hero-board" aria-label="Strategimoduler">
      <p class="board-title">Din strategi, komprimert</p>
      <ul class="board-list">
        <li><span>Rammeverk</span><strong>mål + tidshorisont</strong></li>
        <li><span>Innkjøp</span><strong>faste regler og størrelse</strong></li>
        <li><span>Custody</span><strong>wallet + backup-rutiner</strong></li>
        <li><span>Oppfølging</span><strong>rolig beslutningsprosess</strong></li>
      </ul>

      <div class="network-illustration" aria-hidden="true">
        <svg class="network-world" viewBox="0 0 640 260" role="presentation">
          <path d="M44 86l22-22 48-12 34 7 18 16-5 24-31 18-44 4-30-8-18-16z"></path>
          <path d="M148 122l26-6 15 10-5 18-20 8-18-6-8-14z"></path>
          <path d="M164 168l30-4 20 10-7 31-23 23-19-12-10-19z"></path>
          <path d="M286 68l24-14 48-6 48 9 21 19-8 20-34 14-53 2-28-13z"></path>
          <path d="M354 112l42 5 24 20-9 27-32 18-24-12-10-25z"></path>
          <path d="M420 92l53-10 74 8 45 24-7 22-57 18-64-2-45-20z"></path>
          <path d="M536 168l42-8 30 11 9 19-22 18-42 2-24-14z"></path>
        </svg>

        <svg class="network-lines" viewBox="0 0 640 260" role="presentation">
          <path class="core" d="M116 98Q228 74 356 86"></path>
          <path class="core" d="M116 98Q308 90 518 94"></path>
          <path class="core" d="M356 86Q438 80 518 94"></path>
          <path class="core" d="M356 86Q358 120 364 146"></path>
          <path class="core" d="M116 102Q158 138 186 188"></path>
          <path class="core" d="M356 90Q272 138 186 188"></path>
          <path class="core" d="M518 96Q540 136 560 184"></path>
          <path class="core" d="M364 148Q454 168 560 184"></path>
          <path d="M78 106Q228 104 356 86"></path>
          <path d="M98 84Q232 90 518 94"></path>
          <path d="M138 126Q252 124 518 96"></path>
          <path d="M164 116Q300 108 356 86"></path>
          <path d="M174 114Q266 146 364 148"></path>
          <path d="M184 188Q314 214 560 184"></path>
          <path d="M204 208Q320 182 518 96"></path>
          <path d="M364 148Q322 182 212 220"></path>
          <path d="M364 148Q432 136 482 122"></path>
          <path d="M364 148Q466 160 608 180"></path>
          <path d="M356 86Q446 118 560 184"></path>
          <path d="M518 94Q436 112 364 148"></path>
          <path d="M560 184Q478 136 356 86"></path>
          <path d="M92 70Q180 86 356 86"></path>
          <path d="M74 122Q164 126 186 188"></path>
          <path d="M436 138Q500 158 560 184"></path>
        </svg>

        <svg class="network-flow" viewBox="0 0 640 260" role="presentation">
          <path d="M116 98Q228 74 356 86"></path>
          <path d="M116 98Q308 90 518 94"></path>
          <path d="M356 86Q438 80 518 94"></path>
          <path d="M356 90Q272 138 186 188"></path>
          <path d="M518 96Q540 136 560 184"></path>
          <path d="M364 148Q454 168 560 184"></path>
        </svg>

        <div class="network-nodes">
          <span class="node hub" style="--x:18%;--y:37%;--delay:0s;"></span>
          <span class="node hub" style="--x:55.6%;--y:33.5%;--delay:0.5s;"></span>
          <span class="node hub" style="--x:81.2%;--y:36%;--delay:1s;"></span>
          <span class="node hub warm" style="--x:57.2%;--y:56%;--delay:1.5s;"></span>
          <span class="node hub mint" style="--x:29%;--y:72%;--delay:2s;"></span>

          <span class="node" style="--x:11%;--y:33%;--delay:0.2s;"></span>
          <span class="node mint" style="--x:13%;--y:40%;--delay:0.9s;"></span>
          <span class="node warm" style="--x:15%;--y:45%;--delay:1.8s;"></span>
          <span class="node" style="--x:21%;--y:30%;--delay:1.3s;"></span>
          <span class="node pink" style="--x:23%;--y:42%;--delay:2.4s;"></span>
          <span class="node mint" style="--x:26%;--y:48%;--delay:2.9s;"></span>
          <span class="node warm" style="--x:30%;--y:61%;--delay:0.7s;"></span>
          <span class="node" style="--x:32%;--y:78%;--delay:2.1s;"></span>

          <span class="node" style="--x:49%;--y:31%;--delay:0.4s;"></span>
          <span class="node mint" style="--x:51%;--y:40%;--delay:1.1s;"></span>
          <span class="node pink" style="--x:54%;--y:29%;--delay:2.2s;"></span>
          <span class="node warm" style="--x:58%;--y:36%;--delay:2.7s;"></span>
          <span class="node" style="--x:60%;--y:44%;--delay:3.2s;"></span>
          <span class="node mint" style="--x:56%;--y:62%;--delay:1.4s;"></span>
          <span class="node warm" style="--x:59%;--y:68%;--delay:2.6s;"></span>

          <span class="node" style="--x:69%;--y:34%;--delay:0.6s;"></span>
          <span class="node mint" style="--x:73%;--y:38%;--delay:1.6s;"></span>
          <span class="node pink" style="--x:76%;--y:44%;--delay:2.8s;"></span>
          <span class="node warm" style="--x:79%;--y:52%;--delay:3.1s;"></span>
          <span class="node" style="--x:84%;--y:47%;--delay:0.95s;"></span>
          <span class="node mint" style="--x:88%;--y:41%;--delay:1.95s;"></span>
          <span class="node pink" style="--x:90%;--y:66%;--delay:2.95s;"></span>
          <span class="node warm" style="--x:86%;--y:73%;--delay:3.4s;"></span>
        </div>
      </div>
    </aside>
  </section>

  <section class="section reveal delay-2" id="tjenester">
    <p class="eyebrow">Tjenester</p>
    <h2>Tre moduler for å få kontroll på helheten.</h2>
    <div class="modules-grid section">
      <article class="module-card">
        <div class="module-visual module-visual-1" aria-hidden="true">
          <span></span><span></span><span></span>
        </div>
        <p class="module-index">01</p>
        <h3>Strategi og risikoramme</h3>
        <p>
          Vi definerer mål, tidshorisont og akseptabel risiko slik at bitcoin får
          riktig rolle i totalporteføljen din.
        </p>
      </article>

      <article class="module-card">
        <div class="module-visual module-visual-2" aria-hidden="true">
          <span></span><span></span><span></span>
        </div>
        <p class="module-index">02</p>
        <h3>Innkjøp og oppbevaring</h3>
        <p>
          Konkrete anbefalinger for kjøpsstruktur, wallet-oppsett og sikker
          lagring av nøkler.
        </p>
      </article>

      <article class="module-card">
        <div class="module-visual module-visual-3" aria-hidden="true">
          <span></span><span></span><span></span>
        </div>
        <p class="module-index">03</p>
        <h3>Rutiner og beslutningsstøtte</h3>
        <p>
          Tydelige sjekkpunkter for når du handler, når du holder, og når du
          gjør ingenting.
        </p>
      </article>
    </div>
  </section>

  <section class="section reveal delay-3 process-section">
    <p class="eyebrow">Slik jobber vi</p>
    <h2>Rask prosess, tydelige leveranser.</h2>
    <div class="process-grid section">
      <article class="process-card">
        <p class="process-step">Steg 1</p>
        <h3>Kartlegging</h3>
        <p>Vi går gjennom nåsituasjon, risikoprofil og mål på 45 minutter.</p>
      </article>
      <article class="process-card">
        <p class="process-step">Steg 2</p>
        <h3>Strategidokument</h3>
        <p>Du får en konkret plan for eksponering, kjøp, custody og oppfølging.</p>
      </article>
      <article class="process-card">
        <p class="process-step">Steg 3</p>
        <h3>Implementering</h3>
        <p>Vi setter opp rutiner og beslutningsrammer du kan følge over tid.</p>
      </article>
    </div>
  </section>

  <section class="grid-two section reveal delay-4">
    <article class="panel">
      <p class="eyebrow">For hvem</p>
      <h2>For deg som vil ha struktur, ikke støy.</h2>
      <ul class="bullet-list">
        <li>Privatpersoner med betydelig sparekapital</li>
        <li>Bedrifter som vurderer bitcoin i balansen</li>
        <li>Investorer som vil redusere ad hoc-beslutninger</li>
      </ul>
    </article>

    <article class="panel panel-accent">
      <p class="eyebrow">Klar for neste steg?</p>
      <h2>Vi kan starte med en enkel vurderingssamtale.</h2>
      <p>
        Du får en tydelig anbefaling på hva du bør gjøre nå, og hva du bør
        vente med.
      </p>
      <div class="inline-actions">
        <a class="btn primary" href="/contact">Kontakt oss</a>
      </div>
    </article>
  </section>

  <section class="section reveal delay-4">
    <p class="eyebrow">Innsikt</p>
    <h2>Praktiske artikler for langsiktige beslutninger</h2>
    <div class="article-list section">
      {featured.map((article) => <ArticleCard article={article} />)}
    </div>
  </section>
</SiteLayout>
