---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
  title="Bitcoin Strategi | Rådgivning for bedrifter og privatpersoner"
  description="Strategisk bitcoinrådgivning for bedrifter og privatpersoner: volum, allokering, oppbevaring og tydelige beslutningsregler."
>
  <div class="home-clean">
  <section class="hero reveal delay-1 section">
    <article class="hero-copy">
      <p class="eyebrow">Strategisk bitcoinrådgivning</p>
      <h1>Bitcoinrådgivning for bedrifter og privatpersoner — uten hype.</h1>
      <p class="lead">
        Vi hjelper deg med strategi, risikorammer og praktisk gjennomføring:
        volum, allokering, oppbevaring og beslutningsregler.
      </p>
      <div class="inline-actions">
        <a class="btn primary" href="/contact?segment=bedrift">For bedrifter</a>
        <a class="btn ghost" href="/contact?segment=privat">For privatpersoner</a>
      </div>
    </article>
  </section>

  <section class="grid-two section reveal delay-2" id="spor">
    <article class="panel home-choice">
      <p class="eyebrow">Bedriftsløp</p>
      <h2>For ledelse og styre</h2>
      <p>
        Policy, governance og internkontroll for virksomheter som vil ta
        beslutninger med tydelige rammer og dokumentert prosess.
      </p>
      <div class="inline-actions">
        <a class="btn ghost" href="/enterprise">Se bedriftsløp</a>
      </div>
    </article>

    <article class="panel panel-accent home-choice">
      <p class="eyebrow">Privatløp</p>
      <h2>For deg som investerer privat</h2>
      <p>
        Personlig plan for allokering, risikonivå, oppbevaring og oppfølging
        gjennom markedssykluser.
      </p>
      <div class="inline-actions">
        <a class="btn primary" href="/contact?segment=privat">Se privatløp</a>
      </div>
    </article>
  </section>

  <section class="section reveal delay-3" id="leveranse">
    <p class="eyebrow">Hva du får</p>
    <h2>Tre leveranser som skaper ro i beslutningene.</h2>
    <div class="offer-grid section">
      <article class="module-card">
        <p class="module-index">01</p>
        <h3>Strategi for volum og allokering</h3>
        <p>Definerte grenser for eksponering, tempo og kapitalbruk.</p>
      </article>
      <article class="module-card">
        <p class="module-index">02</p>
        <h3>Regler for oppbevaring og oppfølging</h3>
        <p>Tydelige rutiner for sikkerhet, roller og periodisk gjennomgang.</p>
      </article>
      <article class="module-card">
        <p class="module-index">03</p>
        <h3>Skriftlig plan med beslutningsgrenser</h3>
        <p>Et konkret mandat som reduserer ad hoc-beslutninger.</p>
      </article>
    </div>
  </section>

  <section class="section reveal delay-4">
    <article class="panel">
      <p class="eyebrow">Avgrensning</p>
      <h2>Tydelig, profesjonell rolle.</h2>
      <p>
        Vi leverer strategisk rådgivning og rammeverk. Ved behov for juridisk,
        skattemessig eller regnskapsfaglig vurdering samarbeider vi med relevante
        fagmiljøer.
      </p>
    </article>
  </section>

  <section class="section reveal delay-4">
    <article class="panel panel-accent cta-box">
      <p class="eyebrow">Neste steg</p>
      <h2>Klar for en konkret plan?</h2>
      <p>Book et 30-minutters avklaringsmøte.</p>
      <div class="inline-actions">
        <a class="btn primary" href="/contact">Book møte</a>
      </div>
    </article>
  </section>
  </div>
</SiteLayout>
