---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
  title="Enterprise | Bitcoin Strategi"
  description="Enterprise-opplegg for norske virksomheter: governance, compliance og kvartalsvis styring."
>
  <section class="hero reveal delay-1 section">
    <p class="eyebrow">For større selskaper</p>
    <h1>Governance, compliance og drift for treasury-beslutninger.</h1>
    <p class="lead">
      For mellomstore og store virksomheter som trenger styreforankring,
      kontrollstruktur og revisjonsklart beslutningsgrunnlag.
    </p>
    <div class="inline-actions">
      <a class="btn primary" href="/contact">Book enterprise-møte</a>
      <a class="btn ghost" href="/bransjer">Se bruksområder</a>
    </div>
  </section>

  <section class="offer-grid section reveal delay-2">
    <article class="panel">
      <p class="eyebrow">Pakke B</p>
      <h2>Treasury & Governance</h2>
      <p class="price-tag">120k-350k NOK</p>
      <ul class="bullet-list">
        <li>Styrepresentasjon og beslutningsgrunnlag</li>
        <li>Policy-dokument med kontrollpunkter</li>
        <li>Rapporteringsmodell og leverandørkart</li>
      </ul>
    </article>

    <article class="panel panel-accent">
      <p class="eyebrow">Pakke C</p>
      <h2>Enterprise Program</h2>
      <p class="price-tag">Fra 500k NOK + retainer</p>
      <ul class="bullet-list">
        <li>Konsernpolicy og flerfunksjonell forankring</li>
        <li>Compliance blueprint og beredskapsmodell</li>
        <li>Opplæring for økonomi, juridisk og IT</li>
      </ul>
    </article>
  </section>

  <section class="section reveal delay-3 process-section">
    <p class="eyebrow">Leveransemodell</p>
    <h2>Fra mandat til kvartalsvis styring.</h2>
    <div class="process-grid process-grid-4 section">
      <article class="process-card">
        <p class="process-step">Fase 1</p>
        <h3>Mandat og avgrensning</h3>
        <p>Forankring i ledelse/styre med tydelig risikobudsjett.</p>
      </article>
      <article class="process-card">
        <p class="process-step">Fase 2</p>
        <h3>Kontrollarkitektur</h3>
        <p>Roller, internkontroll, signeringsflyt og dokumentasjon.</p>
      </article>
      <article class="process-card">
        <p class="process-step">Fase 3</p>
        <h3>Operativ drift</h3>
        <p>Custody-rutiner, leverandører og hendelseshåndtering.</p>
      </article>
      <article class="process-card">
        <p class="process-step">Fase 4</p>
        <h3>Kvartalsvis styring</h3>
        <p>KPI-er, policy review og beslutningsstøtte over tid.</p>
      </article>
    </div>
  </section>

  <section class="grid-two section reveal delay-4">
    <article class="panel">
      <p class="eyebrow">KPI-er i oppfølging</p>
      <ul class="bullet-list">
        <li>Andel møter til tilbud</li>
        <li>Andel tilbud til avtale</li>
        <li>Snitt ordreverdi og retainer-andel</li>
        <li>Tid til første betalende kunde per segment</li>
      </ul>
    </article>
    <article class="panel">
      <p class="eyebrow">Retainer</p>
      <h2>Månedlig rådgivning for ledelse og styre.</h2>
      <ul class="bullet-list">
        <li>Markedsnotat og beslutningsstøtte</li>
        <li>Policy review og kontrolloppdatering</li>
        <li>Koordinering med regnskap/revisor/juridisk</li>
      </ul>
    </article>
  </section>
</SiteLayout>
