---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
  title="Page Not Found | Bitcoin Strategi"
  description="The page you requested could not be found."
>
  <section class="hero section reveal">
    <p class="eyebrow">[ 404 ]</p>
    <h1>That page is off-chart.</h1>
    <p class="lead">
      It may have moved during migration. Use the homepage or article archive to
      continue.
    </p>
    <div class="inline-actions">
      <a class="btn primary" href="/">Go home</a>
      <a class="btn ghost" href="/articles">Browse articles</a>
    </div>
  </section>
</SiteLayout>
