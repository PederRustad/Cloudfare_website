---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { articles, getArticleBySlug } from "../../data/articles";

export function getStaticPaths() {
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article }
  }));
}

const { article } = Astro.props;
const articleData = article ?? getArticleBySlug(Astro.params.slug ?? "");

if (!articleData) {
  throw new Error("Innsikt ikke funnet");
}
---

<SiteLayout title={`${articleData.title} | Bitcoin Strategi`} description={articleData.description}>
  <article class="article-page section reveal delay-1">
    <p class="pill">{articleData.category}</p>
    <h1>{articleData.title}</h1>
    <div class="meta-row">
      <span>{articleData.readTime}</span>
      <span>{new Date(articleData.published).toLocaleDateString("nb-NO")}</span>
    </div>

    <p>{articleData.description}</p>
    <p class="article-lead">{articleData.intro}</p>

    <h2 class="section">Kortversjon</h2>
    <ul class="simple-list key-points">
      {articleData.bullets.map((bullet) => <li>{bullet}</li>)}
    </ul>

    {
      articleData.sections.map((section) => (
        <section class="article-block section">
          <h2>{section.heading}</h2>
          {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
          {
            section.checklist && (
              <ul class="simple-list">
                {section.checklist.map((item) => <li>{item}</li>)}
              </ul>
            )
          }
        </section>
      ))
    }

    <p class="copy">{articleData.conclusion}</p>

    <div class="inline-actions section">
      <a class="btn ghost" href="/innsikt">Tilbake til innsikt</a>
      <a class="btn primary" href="/contact">Kontakt oss</a>
    </div>
  </article>
</SiteLayout>
