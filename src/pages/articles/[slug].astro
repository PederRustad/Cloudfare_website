---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { articles, getArticleBySlug } from "../../data/articles";

export function getStaticPaths() {
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article }
  }));
}

const { article } = Astro.props;
const articleData = article ?? getArticleBySlug(Astro.params.slug ?? "");

if (!articleData) {
  throw new Error("Artikkel ikke funnet");
}
---

<SiteLayout title={`${articleData.title} | Bitcoin Strategi`} description={articleData.description}>
  <article class="article-page section reveal delay-1">
    <p class="pill">{articleData.category}</p>
    <h1>{articleData.title}</h1>
    <div class="meta-row">
      <span>{articleData.readTime}</span>
      <span>{new Date(articleData.published).toLocaleDateString("nb-NO")}</span>
    </div>

    <p>{articleData.description}</p>

    <p>
      En robust bitcoin-strategi handler ofte om å redusere antall improviserte
      valg. Når rammene er klare, blir gjennomføringen roligere.
    </p>

    <h2 class="section">Hovedpunkter</h2>
    <ul class="simple-list">
      {articleData.bullets.map((bullet) => <li>{bullet}</li>)}
    </ul>

    <p class="copy">
      Disse artiklene er korte med vilje: rask oversikt, konkrete tiltak og lav
      terskel for å gjøre neste riktige steg.
    </p>

    <div class="inline-actions section">
      <a class="btn ghost" href="/articles">Tilbake til artikler</a>
      <a class="btn primary" href="/contact">Kontakt oss</a>
    </div>
  </article>
</SiteLayout>
