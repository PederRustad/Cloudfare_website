---
import SiteLayout from "../../layouts/SiteLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { articles } from "../../data/articles";

const sortedArticles = [...articles].sort((a, b) =>
  a.published > b.published ? -1 : 1
);
---

<SiteLayout
  title="Articles | Bitcoin Strategi"
  description="Practical Bitcoin strategy articles on risk, process, and long-cycle thinking."
>
  <section class="hero section reveal">
    <p class="eyebrow">[ Article Archive ]</p>
    <h1>Strategic notes for disciplined Bitcoin operators.</h1>
    <p class="lead">
      Read short, actionable guides to improve execution quality and maintain
      conviction through volatile periods.
    </p>
  </section>

  <section class="article-list section reveal">
    {sortedArticles.map((article) => <ArticleCard article={article} />)}
  </section>
</SiteLayout>
