---
import SiteLayout from "../../layouts/SiteLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { articles } from "../../data/articles";

const sortedArticles = [...articles].sort((a, b) =>
  a.published > b.published ? -1 : 1
);
---

<SiteLayout
  title="Artikler | Bitcoin Strategi"
  description="Praktiske artikler om bitcoin-strategi, risikostyring og langsiktig beslutningsstruktur."
>
  <section class="hero reveal delay-1 section">
    <p class="eyebrow">Artikler</p>
    <h1>Innsikt skrevet for rolige og langsiktige beslutninger.</h1>
    <p class="lead">
      Ingen signalstøy, bare praktiske rammer for strategi, risiko og gjennomføring.
    </p>
  </section>

  <section class="article-list section reveal delay-2">
    {sortedArticles.map((article) => <ArticleCard article={article} />)}
  </section>
</SiteLayout>
