---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
  title="Kontakt | Bitcoin Strategi"
  description="Kontakt oss for strategisamtale, rådgivning eller spørsmål om bitcoin-risiko."
>
  <section class="hero fade-up delay-1 section">
    <p class="eyebrow">Kontakt</p>
    <h1>Ta kontakt for en uforpliktende strategisamtale.</h1>
    <p class="lead">
      Vi svarer raskt og konkret. Målet er å avklare hva som faktisk er neste
      riktige steg for deg.
    </p>
  </section>

  <section class="contact-grid section fade-up delay-2">
    <article class="contact-card">
      <p class="eyebrow">Direkte</p>
      <h2>E-post</h2>
      <p><a href="mailto:hello@bitcoinstrategi.no">hello@bitcoinstrategi.no</a></p>
      <p>Normal svartid: innen 1-2 virkedager.</p>
    </article>

    <article class="contact-card">
      <p class="eyebrow">Melding</p>
      <h2>Kontaktform</h2>
      <form class="contact-form" action="#" method="post">
        <label for="name">Navn</label>
        <input id="name" name="name" type="text" placeholder="Ditt navn" />

        <label for="email">E-post</label>
        <input id="email" name="email" type="email" placeholder="deg@firma.no" />

        <label for="message">Melding</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          placeholder="Hva ønsker du hjelp med?"
        ></textarea>

        <button class="btn primary" type="submit">Send melding</button>
      </form>
    </article>
  </section>
</SiteLayout>
