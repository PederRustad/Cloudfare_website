---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
  title="Kontakt | Bitcoin Strategi"
  description="Book strategimøte for SMB eller enterprise og få anbefalt neste steg."
>
  <section class="hero reveal delay-1 section">
    <p class="eyebrow">Kontakt</p>
    <h1>Book strategimøte for SMB eller enterprise.</h1>
    <p class="lead">
      Del litt om virksomheten deres, så foreslår vi riktig løp og neste
      konkrete steg.
    </p>
  </section>

  <section class="contact-grid section reveal delay-2">
    <article class="contact-card">
      <p class="eyebrow">Direkte</p>
      <h2>E-post</h2>
      <p><a href="mailto:hello@bitcoinstrategi.no">hello@bitcoinstrategi.no</a></p>
      <p>Normal svartid: innen 1-2 virkedager.</p>
      <p class="copy">
        Foretrekker dere et kort avklaringsmøte først, skriv "avklaringsmøte" i
        emnefeltet.
      </p>
    </article>

    <article class="contact-card">
      <p class="eyebrow">Kvalifisering</p>
      <h2>Fortell oss om bedriften</h2>
      <form class="contact-form" action="#" method="post">
        <label for="company">Selskap</label>
        <input id="company" name="company" type="text" placeholder="Firmanavn AS" />

        <label for="role">Din rolle</label>
        <input id="role" name="role" type="text" placeholder="CEO, CFO, styreleder..." />

        <label for="size">Størrelse</label>
        <select id="size" name="size">
          <option value="">Velg størrelse</option>
          <option value="1-49">1-49 ansatte</option>
          <option value="50-249">50-249 ansatte</option>
          <option value="250+">250+ ansatte</option>
        </select>

        <label for="objective">Mål</label>
        <select id="objective" name="objective">
          <option value="">Velg mål</option>
          <option value="policy">Bygge policy og risikoramme</option>
          <option value="treasury">Etablere treasury-modell</option>
          <option value="compliance">Compliance og internkontroll</option>
          <option value="workshop">Styre-/lederworkshop</option>
        </select>

        <label for="timeline">Tidshorisont</label>
        <select id="timeline" name="timeline">
          <option value="">Velg tidshorisont</option>
          <option value="0-30">0-30 dager</option>
          <option value="30-90">30-90 dager</option>
          <option value="90+">90+ dager</option>
        </select>

        <label for="email">E-post</label>
        <input id="email" name="email" type="email" placeholder="deg@firma.no" />

        <label for="message">Melding</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          placeholder="Kort om nåsituasjon, mål og hva dere trenger hjelp til."
        ></textarea>

        <button class="btn primary" type="submit">Send forespørsel</button>
      </form>
    </article>
  </section>
</SiteLayout>
