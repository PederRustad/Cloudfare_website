---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
  title="About | Bitcoin Strategi"
  description="Learn the mission and editorial principles behind Bitcoin Strategi."
>
  <section class="hero fade-up delay-1 section">
    <p class="eyebrow">About</p>
    <h1>Educational content for rational Bitcoin decision-making.</h1>
    <p class="lead">
      Bitcoin Strategi exists to reduce chaos in how people approach Bitcoin.
      We publish straightforward material that helps readers decide with structure,
      not mood.
    </p>
  </section>

  <section class="grid-three section fade-up delay-2">
    <article class="panel">
      <p class="eyebrow">Mission</p>
      <h2>Make Bitcoin understandable.</h2>
      <p>
        We translate technical and market complexity into plain language and
        usable frameworks.
      </p>
    </article>

    <article class="panel">
      <p class="eyebrow">Principles</p>
      <h2>Clarity over drama.</h2>
      <p>
        No sensational claims. No fear tactics. No chasing short-term narratives.
      </p>
    </article>

    <article class="panel">
      <p class="eyebrow">Goal</p>
      <h2>Long-term consistency.</h2>
      <p>
        Better systems create better behavior. Better behavior creates better
        outcomes.
      </p>
    </article>
  </section>
</SiteLayout>
