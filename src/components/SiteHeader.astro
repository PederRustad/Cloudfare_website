---
const pathname = Astro.url.pathname;

const links = [
  { href: "/", label: "Hjem" },
  { href: "/#tjenester", label: "Tjenester" },
  { href: "/about", label: "Om oss" },
  { href: "/articles", label: "Artikler" },
  { href: "/contact", label: "Kontakt" }
];

function isActive(path: string, href: string): boolean {
  if (href === "/") {
    return path === "/";
  }

  if (href.startsWith("/#")) {
    return path === "/";
  }

  return path === href || path.startsWith(`${href}/`);
}
---

<header class="site-header">
  <a class="brand" href="/" aria-label="Gå til forsiden">
    <span class="brand-mark" aria-hidden="true">B</span>
    <span class="brand-copy">
      bitcoinstrategi.no
      <small>Strategisk bitcoin-rådgivning</small>
    </span>
  </a>

  <button class="menu-trigger" aria-label="Åpne meny" data-menu-trigger>
    Meny
  </button>

  <nav class="site-nav" data-site-nav>
    {
      links.map((link) => (
        <a class={isActive(pathname, link.href) ? "active" : ""} href={link.href}>
          {link.label}
        </a>
      ))
    }
  </nav>
</header>
